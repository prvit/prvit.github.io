---
---

<section
  id="hero"
  class="pt-[120px] lg:pt-[160px] pb-20 lg:pb-28"
  aria-labelledby="hero-name"
>
  <div class="max-w-site mx-auto px-5 md:px-8 lg:px-12">
    <div class="max-w-main">

      <!-- Eyebrow row: location + availability badge -->
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <div class="flex items-center gap-2">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--color-text-muted);">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="eyebrow">Krakow, Poland</span>
        </div>
        <!-- Availability signal — highest-impact recruiter conversion element -->
        <span
          class="inline-flex items-center gap-1.5 font-mono text-xs px-2.5 py-1 rounded-full"
          style="background-color: rgba(61, 153, 112, 0.12); color: var(--color-success); border: 1px solid rgba(61, 153, 112, 0.3);"
          aria-label="Currently open to new roles"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-current" aria-hidden="true" style="animation: pulse 2s cubic-bezier(0.4,0,0.6,1) infinite;"></span>
          Open to new roles
        </span>
      </div>

      <!-- Name -->
      <h1
        id="hero-name"
        class="text-3xl lg:text-4xl font-semibold leading-tight mb-3"
        style="color: var(--color-text-primary); letter-spacing: -0.02em;"
      >
        Vitalii Prokopchuk
      </h1>

      <!-- Title -->
      <p
        class="font-mono text-lg mb-6"
        style="color: var(--color-text-secondary);"
      >
        Senior Software Engineer &mdash; Distributed Systems &mdash; .NET &amp; Azure
      </p>

      <!-- Tagline: concrete scale signal front-loaded, not buried in the metrics strip -->
      <p
        class="text-lg lg:text-xl mb-10 leading-relaxed"
        style="color: var(--color-text-secondary);" class="max-w-[560px] lg:max-w-[720px]"
      >
        Senior Software Engineer with
        <span style="color: var(--color-text-primary);">14+ years</span>
        designing and scaling distributed systems. Deep expertise in
        <span style="color: var(--color-text-primary);">.NET and Azure</span>,
        but pragmatic about technology choices — I select tools based on the problem and have shipped production systems with Node.js, React, ML.NET, and iOS when appropriate.
      </p>

      <!-- CTA Row -->
      <div class="flex flex-wrap items-center gap-3" role="group" aria-label="Profile links and downloads">
        <!-- GitHub -->
        <a
          href="https://github.com/prvit"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-ghost"
          aria-label="GitHub profile (opens in new tab)"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/vitalii-prokopchuk"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-ghost"
          aria-label="LinkedIn profile (opens in new tab)"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>

        <!-- Download CV -->
        <a
          href="/cv.pdf"
          download="Vitalii_Prokopchuk_CV.pdf"
          class="btn-primary"
          aria-label="Download Vitalii Prokopchuk CV as PDF"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download CV
        </a>
      </div>

      <!-- Metrics strip -->
      <div
        class="mt-14 pt-8 grid grid-cols-2 sm:grid-cols-4 gap-6"
        style="border-top: 1px solid var(--color-border);"
        aria-label="Key metrics"
      >
        {[
          { value: '8M+', label: 'Chevron platform users' },
          { value: '2M+', label: 'Monthly transactions' },
          { value: '~100 requests/s', label: 'Backend throughput' },
        ].map(({ value, label }) => (
          <div>
            <div
              class="text-2xl font-semibold leading-none mb-1"
              style="color: var(--color-accent); letter-spacing: -0.02em;"
            >
              {value}
            </div>
            <div class="text-xs" style="color: var(--color-text-muted);">{label}</div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
