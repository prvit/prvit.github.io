---
interface Achievement {
  text: string;
}

interface ExperienceItem {
  id: string;
  company: string;
  role: string;
  period: string;
  location: string;
  isCurrent?: boolean;
  isDefaultOpen?: boolean;
  achievements: Achievement[];
  tech: string[];
  url?: string;
}

const experiences: ExperienceItem[] = [
  {
    id: 'par-technology',
    company: 'PAR Technology',
    role: 'Senior Software Engineer',
    period: 'May 2021 — Present',
    location: 'Krakow, Poland · Remote · Client: Chevron',
    isCurrent: true,
    isDefaultOpen: true,
    achievements: [
      { text: 'Built a configurable graph-based loyalty rules engine for transaction processing — config-driven, ordering-aware, and used as rollout infrastructure for product features' },
      { text: 'Developed migration tooling supporting dual loyalty providers during Chevron\'s OpenCommerce transition' },
      { text: 'Introduced .NET Aspire for local development orchestration, replacing manual multi-service startup with a single command workflow' },
    ],
    tech: ['C#', '.NET', 'ASP.NET Core', 'GraphQL', 'REST APIs', 'Azure Functions', 'Azure Service Bus', 'Redis', 'Azure Blob Storage', 'SQL Server', 'Docker', '.NET Aspire'],
  },
  {
    id: 'strategic-vision',
    company: 'Strategic Vision',
    role: 'Senior Software Engineer',
    period: 'May 2017 — May 2021',
    location: 'San Diego, USA · Remote',
    achievements: [
      { text: 'Built NLP pipelines for processing survey verbatims using ML.NET and external ML providers' },
      { text: 'Integrated Qualtrics REST APIs for survey ingestion and data pipelines' },
      { text: 'Developed real-time survey visualization platforms and automated reporting systems' },
      { text: 'Built a vehicle recommendation engine based on structured buyer preferences' },
    ],
    tech: ['C#', '.NET Framework', '.NET Core', 'ASP.NET MVC', 'ASP.NET Core Web API', 'React', 'Redux', 'ML.NET', 'IBM Watson', 'Qualtrics APIs', 'SQL Server', 'MySQL', 'Entity Framework'],
  },
  {
    id: 'letmepark',
    company: 'LetMePark',
    role: 'Co-founder & CTO',
    period: 'Jul 2017 — Oct 2019',
    location: 'Madrid, Spain · Remote',
    url: 'https://letmepark.app/en',
    achievements: [
      { text: 'Built the complete technical platform as the sole technical founder' },
      { text: 'Integrated license plate recognition providers for automated parking access' },
      { text: 'Designed system architecture supporting partner integrations and connected vehicle platforms' },
    ],
    tech: ['.NET', 'Node.js', 'iOS (native)', 'Azure', 'SQL Server'],
  },
  {
    id: 'materialise',
    company: 'Materialise',
    role: 'Software Engineer',
    period: 'Nov 2014 — May 2017',
    location: 'Kyiv, Ukraine',
    achievements: [
      { text: 'Led monolith-to-microservices migration from ASP.NET MVC to Web API architecture' },
      { text: 'Built browser-based WebGL 3D model viewer' },
      { text: 'Developed public APIs for third-party developer integrations' },
    ],
    tech: ['C#', '.NET', 'ASP.NET MVC', 'Web API', 'Angular.js', 'WCF', 'Entity Framework', 'SQL Server', 'JavaScript'],
  },
  {
    id: 'softserve',
    company: 'SoftServe',
    role: 'Software Engineer',
    period: 'Feb 2014 — Dec 2014',
    location: 'Kyiv, Ukraine',
    achievements: [
      { text: 'Worked on enterprise Master Data Management software and educational platforms' },
    ],
    tech: ['C#', '.NET', 'ASP.NET', 'WCF', 'SQL Server', 'Entity Framework', 'Knockout.js'],
  },
  {
    id: 'alpha-quant',
    company: 'Alpha Quant Partners',
    role: 'Junior Software Engineer',
    period: 'Sep 2012 — Oct 2013',
    location: 'Kyiv, Ukraine',
    achievements: [
      { text: 'Built WinForms trading tools for NYSE market operations using the RealTick API' },
    ],
    tech: ['C#', '.NET', 'WinForms', 'RealTick API'],
  },
];
---

<section
  id="experience"
  class="py-16 lg:py-24"
  aria-labelledby="experience-heading"
>
  <div class="max-w-site mx-auto px-5 md:px-8 lg:px-12">

    <p class="eyebrow mb-4">Experience</p>
    <h2
      id="experience-heading"
      class="text-2xl lg:text-3xl font-semibold mb-10"
      style="color: var(--color-text-primary); letter-spacing: -0.02em;"
    >
      Where I've worked
    </h2>

    <div class="space-y-3" role="list">
      {experiences.map((exp) => (
        <article
          class="exp-card rounded-lg"
          data-open={exp.isDefaultOpen ? 'true' : 'false'}
          style={`background-color: var(--color-surface); border: 1px solid ${exp.isCurrent ? 'var(--color-accent-subtle)' : 'var(--color-border)'};${exp.isCurrent ? ' border-left: 3px solid var(--color-accent);' : ''}`}
          role="listitem"
        >
          <!-- Card Header (always visible, clickable) -->
          <button
            class="exp-card-header w-full text-left px-5 py-4 flex items-start justify-between gap-4 group"
            aria-expanded={exp.isDefaultOpen ? 'true' : 'false'}
            aria-controls={`exp-body-${exp.id}`}
          >
            <div class="min-w-0 flex-1">
              <!-- Company + badge row -->
              <div class="flex flex-wrap items-center gap-2 mb-1">
                <span
                  class="font-mono text-sm"
                  style="color: var(--color-text-secondary);"
                >
                  {exp.company}
                </span>
                {exp.isCurrent && (
                  <span class="badge-current" aria-label="Current position">
                    Current
                  </span>
                )}
                {exp.url && (
                  <a
                    href={exp.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 font-mono text-xs transition-colors duration-150"
                    style="color: var(--color-text-muted);"
                    aria-label={`Visit ${exp.company} website (opens in new tab)`}
                    onClick={(e) => e.stopPropagation()}
                  >
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/>
                      <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                    letmepark.app
                  </a>
                )}
              </div>

              <!-- Role -->
              <h3
                class="text-xl font-medium leading-snug"
                style="color: var(--color-text-primary);"
              >
                {exp.role}
              </h3>

              <!-- Dates + Location -->
              <div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-1.5">
                <span
                  class="font-mono text-xs"
                  style="color: var(--color-text-muted);"
                >
                  {exp.period}
                </span>
                <span
                  class="font-mono text-xs"
                  style="color: var(--color-text-muted);"
                >
                  {exp.location}
                </span>
              </div>
            </div>

            <!-- Chevron -->
            <div
              class="exp-expand-icon flex-shrink-0 mt-1"
              style="color: var(--color-text-muted);"
              aria-hidden="true"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </div>
          </button>

          <!-- Collapsible Body -->
          <div
            class="exp-card-body"
            id={`exp-body-${exp.id}`}
          >
            <div class="exp-card-body-inner">
              <div
                class="px-5 pb-5 pt-2"
                style="border-top: 1px solid var(--color-border-muted);"
              >
                {exp.achievements.length > 0 && (
                  <ul class="space-y-2.5 mb-5" aria-label={`Achievements at ${exp.company}`}>
                    {exp.achievements.map(({ text }) => (
                      <li class="flex gap-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                        <span style="color: var(--color-text-muted); flex-shrink: 0; margin-top: 1px;" aria-hidden="true">&mdash;</span>
                        <span>{text}</span>
                      </li>
                    ))}
                  </ul>
                )}

                <!-- Tech tags -->
                <div class="flex flex-wrap gap-1.5" aria-label={`Technologies used at ${exp.company}`}>
                  {exp.tech.map((tag) => (
                    <span class="tag-pill">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('.exp-card-header').forEach(header => {
    header.addEventListener('click', () => {
      const card = header.closest('.exp-card') as HTMLElement;
      if (!card) return;
      const isOpen = card.dataset.open === 'true';
      card.dataset.open = isOpen ? 'false' : 'true';
      header.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });
  });
</script>
