---
const year = new Date().getFullYear();
---

<footer
  class="py-8"
  style="border-top: 1px solid var(--color-border);"
  aria-label="Site footer"
>
  <div class="max-w-site mx-auto px-5 md:px-8 lg:px-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3">

      <!-- Copyright -->
      <p
        class="font-mono text-xs"
        style="color: var(--color-text-muted);"
      >
        &copy; {year} Vitalii Prokopchuk. All rights reserved.
      </p>

      <!-- Site URL -->
      <a
        href="https://vitalii.prokopchuk.dev"
        class="font-mono text-xs transition-colors duration-150"
        style="color: var(--color-text-muted);"
        aria-label="Homepage: vitalii.prokopchuk.dev"
      >
        vitalii.prokopchuk.dev
      </a>

    </div>
  </div>
</footer>
