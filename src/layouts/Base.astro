---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Vitalii Prokopchuk — Senior Software Engineer | .NET & Azure | Distributed Systems',
  description = 'Senior Software Engineer with 14+ years designing and scaling distributed systems. Deep expertise in .NET and Azure. Currently building backend infrastructure for Chevron\'s fuel retail platform at PAR Technology. Based in Krakow, Poland.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Vitalii Prokopchuk',
  jobTitle: 'Senior Software Engineer',
  description: description,
  url: 'https://prvit.github.io',
  email: 'vitalii@prokopchuk.dev',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Krakow',
    addressCountry: 'PL',
  },
  worksFor: {
    '@type': 'Organization',
    name: 'PAR Technology',
    url: 'https://www.partech.com',
  },
  seeks: {
    '@type': 'JobPosting',
    description: 'Open to Senior Software Engineer, Tech Lead, Team Lead, and Solutions Architect roles. Remote or hybrid (Krakow). Available for new opportunities.',
    employmentType: ['FULL_TIME', 'CONTRACTOR'],
    jobLocation: {
      '@type': 'Place',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Krakow',
        addressCountry: 'PL',
      },
    },
  },
  sameAs: [
    'https://www.linkedin.com/in/vitalii-prokopchuk',
    'https://github.com/prvit',
  ],
  knowsAbout: [
    'Distributed Systems',
    '.NET',
    'Azure',
    'C#',
    'ASP.NET Core',
    'GraphQL',
    'Node.js',
    'React',
    'ML.NET',
    'iOS',
    'Software Architecture',
    'Technical Leadership',
  ],
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'National Aviation University',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Kyiv',
      addressCountry: 'UA',
    },
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Vitalii Prokopchuk" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Vitalii Prokopchuk — Senior Software Engineer, .NET & Azure" />
    <meta property="og:site_name" content="Vitalii Prokopchuk" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Vitalii Prokopchuk — Senior Software Engineer, .NET & Azure" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
